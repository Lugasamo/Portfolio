{# user/themes/your-theme/templates/partials/profile-block.html.twig #}

{# Get the blocks page and access the profile data from its header #}
{% set blocks_page = pages.find('/blocks') %}

{% if blocks_page and blocks_page.header.profile %}
  {% set profile = blocks_page.header.profile %}
  {% set columnl = blocks_page.header.columnl %}
  {% set columnr = blocks_page.header.columnr %}
  
  {# ✅ Profile Section (reusable structured content) #}
  <section class="mx-0 mb-24 flex-none lg:flex space-y-6 p-site bg-gradient-to-b from-white to-gray-100 rounded-b-3xl">
      <div class="flex flex-col lg:flex-row w-full space-y-4">
          <div class="content-center w-56 h-auto space-y-4 px-6 {# bg-red-300 #} m-auto lg:m">
          {# Image Content #}
              {% set profileImage = blocks_page.media[profile.image] ?? null %}
              {% if profileImage %}
              <img 
                  src="{{ profileImage.url }}"
                  alt="{{ profile.name ?: 'Profile Picture' }}" 
                  class="transition-transform duration-300 hover:scale-105"
                  loading="lazy"
              >
              {% endif %}
          </div>
          <div class="flex-1 w-full content-center space-y-4 px-6 {# bg-orange-300 #} text-center lg:text-left">
          {# Text Content #}
              <h2>{{ profile.name }}</h2>
              <p>{{ profile.bio }}</p>
          </div>
      </div>
      <div class="flex flex-col xl:flex-row flex-auto w-auto {# bg-blue-300 #}">
          <h3 class="w-full lg:w-80 content-center leading-7 xl:leading-10 text-center">
          {# Skills Content #}
              {{ columnl.skills | raw }}
          </h3>
          <h3 class="w-full lg:w-80 content-center leading-7 xl:leading-10 text-center">
          {# Skills Content #}
              {{ columnr.skills | raw }}
          </h3>  
      </div>
  </section>
{% else %}
  <div class="error-message bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
    <strong>Error:</strong> Profile block data not found in /blocks page.
  </div>
{% endif %}
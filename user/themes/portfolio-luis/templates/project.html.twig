{% extends 'partials/base.html.twig' %}
{% block content %}

{# Hero Section #} 
{% if page.header.title %}
  {% include 'partials/hero.html.twig' %}
{% endif %}

<div class="flex flex-col lg:flex-row gap-x-4 md:gap-x-4 lg:gap-x-8 sm:gap-y-4 gap-y-6 p-site pt-0 bg-gradient-to-b to-white from-gray-100">
  
  {# Main Content #}
  <main class="p-site m-auto w-full lg:w-2/3 shadow-lg rounded-3xl bg-white bg-opacity-90 delay-[100ms] duration-[600ms] taos:translate-y-[2%] taos:opacity-0" data-taos-offset="300">
    {% if page.content %}
      <div class="flex-col space-y-12">
        
        {# Project Introduction #}
        <section class="project-intro mb-8">
          {% if page.header.hero_title %}
            <h2 class="mb-4">{{ page.header.hero_title|raw }}</h2>
          {% endif %}
          
          {% if page.content %}
            <div class="prose prose-lg max-w-none">
              {{ page.content|raw }}
            </div>
          {% endif %}
        </section>

        {# Content Blocks Section - Enhanced with adaptive layouts and video support #}
        {% if page.header.content_blocks %}
          <section class="content-blocks my-12">
            {% for block in page.header.content_blocks %}
              {% set loop_index = loop.index0 %}
              {% set is_even = (loop_index % 2) == 0 %}
              
              {# Check what content we have #}
              {% set hasImage = block.image and block.image|length > 0 %}
              {% set hasVideo = block.video and block.video|length > 0 %}
              {% set hasVideoUrl = block.video_url and block.video_url|length > 0 %}
              {% set hasText = block.title or block.content %}
              {% set hasImageFile = false %}
              {% set hasVideoFile = false %}
              {% set hasMedia = false %}
              
              {# Check media type preference #}
              {% set media_type = block.media_type|default('image') %}
              
              {# Check if image file actually exists #}
              {% if hasImage and media_type == 'image' %}
                {% for filename, file in block.image %}
                  {% if loop.first and page.media[filename] %}
                    {% set hasImageFile = true %}
                    {% set hasMedia = true %}
                  {% endif %}
                {% endfor %}
              {% endif %}
              
              {# Check if video file exists or video URL is provided #}
              {% if media_type == 'video' %}
                {% if hasVideo %}
                  {% for filename, file in block.video %}
                    {% if loop.first and page.media[filename] %}
                      {% set hasVideoFile = true %}
                      {% set hasMedia = true %}
                    {% endif %}
                  {% endfor %}
                {% elseif hasVideoUrl %}
                  {% set hasMedia = true %}
                {% endif %}
              {% endif %}
              
              {# Determine text position #}
              {% set text_position = block.text_position|default('auto') %}
              {% set text_left = text_position == 'auto' ? is_even : (text_position == 'left') %}

              {# Adaptive container classes based on content availability #}
              {% if hasMedia and hasText %}
                {# Both media and text - original 2-column layout #}
                <div class="content-block grid grid-cols-1 lg:grid-cols-2 gap-8 py-12 items-center {{ text_left ? 'lg:grid-flow-col' : 'lg:grid-flow-col-dense' }} delay-[100ms] duration-[600ms] taos:translate-y-[2%] taos:opacity-0" data-taos-offset="300">
              {% elseif hasMedia and not hasText %}
                {# Media only - centered layout #}
                <div class="content-block flex justify-center items-center py-12 delay-[100ms] duration-[600ms] taos:translate-y-[2%] taos:opacity-0" data-taos-offset="300">
              {% elseif hasText and not hasMedia %}
                {# Text only - centered, full width layout #}
                <div class="content-block flex justify-center items-center py-12 delay-[100ms] duration-[600ms] taos:translate-y-[2%] taos:opacity-0" data-taos-offset="300">
              {% endif %}
                
                {# Text Content #}
                {% if hasText %}
                  <div class="text-content 
                              {% if hasMedia and hasText %}
                                {{ text_left ? 'lg:order-1' : 'lg:order-2' }}
                              {% elseif hasText and not hasMedia %}
                                w-full max-w-4xl text-center
                              {% endif %}">
                    {% if block.title %}
                      <h3 class="mb-4 font-medium">{{ block.title }}</h3>
                    {% endif %}
                    {% if block.content %}
                      <div class="prose max-w-none {{ hasMedia ? '' : 'prose-center mx-auto' }}">
                        {{ block.content|markdown }}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}

                {# Media Content - Image or Video #}
                {% if hasMedia %}
                  <div class="media-content 
                              {% if hasMedia and hasText %}
                                {{ text_left ? 'lg:order-2' : 'lg:order-1' }}
                              {% elseif hasMedia and not hasText %}
                                w-full max-w-4xl
                              {% endif %}">
                    
                    {# Image Content #}
                    {% if hasImageFile and media_type == 'image' %}
                      {% for filename, file in block.image %}
                        {% if loop.first and page.media[filename] %}
                          <img 
                            src="{{ page.media[filename].url }}" 
                            alt="{{ block.title|default('Content Image') }}"
                            class="w-full rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300 
                                  {{ hasText ? '' : 'mx-auto' }}"
                            loading="lazy"
                          >
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                    
                    {# Video Content #}
                    {% if media_type == 'video' %}
                      {# Local Video File #}
                      {% if hasVideoFile %}
                        {% for filename, file in block.video %}
                          {% if loop.first and page.media[filename] %}
                            
                            {# Get poster image if available #}
                            {% set poster_image = '' %}
                            {% if block.video_poster %}
                              {% for poster_filename, poster_file in block.video_poster %}
                                {% if loop.first and page.media[poster_filename] %}
                                  {% set poster_image = page.media[poster_filename].url %}
                                {% endif %}
                              {% endfor %}
                            {% endif %}
                            
                            {# Build video attributes array #}
                            {% set video_attrs = [] %}
                            
                            {# Convert string values to booleans for easier checking #}
                            {% set is_autoplay = block.video_autoplay == 1 or block.video_autoplay == '1' or block.video_autoplay == true %}
                            {% set is_loop = block.video_loop == 1 or block.video_loop == '1' or block.video_loop == true %}
                            {% set is_muted = block.video_muted == 1 or block.video_muted == '1' or block.video_muted == true %}
                            {% set show_controls = block.video_controls is not defined or block.video_controls == 1 or block.video_controls == '1' or block.video_controls == true %}
                            
                            {# Handle controls - show by default unless explicitly disabled or autoplay without controls #}
                            {% if show_controls and not is_autoplay %}
                              {% set video_attrs = video_attrs|merge(['controls']) %}
                            {% endif %}
                            
                            {# Handle autoplay - always include muted and playsinline for browser compatibility #}
                            {% if is_autoplay %}
                              {% set video_attrs = video_attrs|merge(['autoplay', 'muted', 'playsinline']) %}
                            {% endif %}
                            
                            {# Handle loop #}
                            {% if is_loop %}
                              {% set video_attrs = video_attrs|merge(['loop']) %}
                            {% endif %}
                            
                            {# Handle muted (if not autoplay, check separate muted setting) #}
                            {% if is_muted and not is_autoplay %}
                              {% set video_attrs = video_attrs|merge(['muted']) %}
                            {% endif %}
                            
                            {# Add preload #}
                            {% set video_attrs = video_attrs|merge(['preload="auto"']) %}
                            
                            <video 
                              class="w-full rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300 {{ hasText ? '' : 'mx-auto' }}"
                              {{ video_attrs|join(' ')|raw }}
                              {% if poster_image %}poster="{{ poster_image }}"{% endif %}
                            >
                              <source src="{{ page.media[filename].url }}" type="{{ page.media[filename].mime }}">
                              <p>Your browser doesn't support HTML video. <a href="{{ page.media[filename].url }}">Download the video</a> instead.</p>
                            </video>
                          {% endif %}
                        {% endfor %}
                        
                      {# YouTube/Vimeo Embed #}
                      {% elseif hasVideoUrl %}
                        {% set video_id = '' %}
                        {% set embed_url = '' %}
                        {% set autoplay_params = '' %}
                        
                        {# Build autoplay parameters #}
                        {% set is_autoplay = block.video_autoplay == 1 or block.video_autoplay == '1' or block.video_autoplay == true %}
                        {% set is_loop = block.video_loop == 1 or block.video_loop == '1' or block.video_loop == true %}
                        {% set show_controls = block.video_controls is not defined or block.video_controls == 1 or block.video_controls == '1' or block.video_controls == true %}
                        
                        {% if is_autoplay %}
                          {% set autoplay_params = '?autoplay=1&mute=1' %}
                          {% if is_loop %}
                            {% set autoplay_params = autoplay_params ~ '&loop=1' %}
                          {% endif %}
                        {% elseif is_loop %}
                          {% set autoplay_params = '?loop=1' %}
                        {% endif %}
                        
                        {# YouTube URL processing #}
                        {% if 'youtube.com' in block.video_url or 'youtu.be' in block.video_url %}
                          {% if 'youtu.be' in block.video_url %}
                            {% set video_id = block.video_url|split('youtu.be/')|last|split('?')|first %}
                          {% else %}
                            {% set video_id = block.video_url|split('v=')|last|split('&')|first %}
                          {% endif %}
                          {% set embed_url = 'https://www.youtube.com/embed/' ~ video_id ~ autoplay_params %}
                          {# Add playlist parameter for loop to work on YouTube #}
                          {% if is_loop %}
                            {% if autoplay_params %}
                              {% set embed_url = embed_url ~ '&playlist=' ~ video_id %}
                            {% else %}
                              {% set embed_url = embed_url ~ '?playlist=' ~ video_id %}
                            {% endif %}
                          {% endif %}
                          {# Handle controls for autoplay #}
                          {% if is_autoplay and not show_controls %}
                            {% set embed_url = embed_url ~ '&controls=0&showinfo=0&rel=0' %}
                          {% endif %}
                          
                        {# Vimeo URL processing #}
                        {% elseif 'vimeo.com' in block.video_url %}
                          {% set video_id = block.video_url|split('vimeo.com/')|last|split('?')|first %}
                          {% set embed_url = 'https://player.vimeo.com/video/' ~ video_id ~ autoplay_params %}
                          {# Handle controls for Vimeo autoplay #}
                          {% if is_autoplay and not show_controls %}
                            {% set embed_url = embed_url ~ '&background=1' %}
                          {% endif %}
                        {% endif %}
                        
                        {% if embed_url %}
                          <div class="relative w-full aspect-video rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow duration-300">
                            <iframe 
                              src="{{ embed_url }}"
                              class="absolute inset-0 w-full h-full"
                              frameborder="0"
                              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                              allowfullscreen
                            ></iframe>
                          </div>
                        {% else %}
                          <div class="w-full p-8 bg-gray-100 rounded-lg text-center">
                            <p class="text-gray-600">Unsupported video URL format</p>
                            <a href="{{ block.video_url }}" class="text-blue-600 hover:underline" target="_blank" rel="noopener">
                              View Video
                            </a>
                          </div>
                        {% endif %}
                      {% endif %}
                    {% endif %}
                    
                  </div>
                {% endif %}
                
              </div>
            {% endfor %}
          </section>
        {% endif %}

        {# Project Media Gallery #}
        {% if page.header.project_media %}
          <section class="project-gallery">
            <h3 class="mb-6">UI Showcase</h3>
            <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6">
              {% for file in page.header.project_media %}
                {# Skip the first image since it's used as cover #}
                {% if not loop.first %}
                  {% set image = page.media.images[file.name] %}
                  {% set video = page.media.files[file.name] %}
                  
                  {% if image %}
                    <div class="gallery-item delay-[300ms] duration-[600ms] taos:translate-y-[10%] taos:opacity-0" data-taos-offset="300">
                      <img
                        src="{{ image.url }}"
                        alt="{{ file.name }}"
                        class="w-full aspect-video object-cover rounded-xl shadow cursor-pointer hover:shadow-lg transition-shadow duration-300"
                        loading="lazy"
                        onclick="openModal({{ loop.index0 - 1 }})"
                      />
                    </div>
                  {% elseif video and video.type starts with 'video' %}
                    <div class="gallery-item delay-[300ms] duration-[600ms] taos:translate-y-[10%] taos:opacity-0" data-taos-offset="300">
                      <video
                        controls
                        class="w-full aspect-video object-cover rounded-xl shadow cursor-pointer hover:shadow-lg transition-shadow duration-300"
                        preload="metadata"
                        onclick="openModal({{ loop.index0 - 1 }})"
                      >
                        <source src="{{ video.url }}" type="{{ video.type }}">
                        Your browser does not support the video tag.
                      </video>
                    </div>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          </section>
        {% endif %}

      </div>
    {% endif %}
  </main>

  {# Sidebar #}
  <aside class="lg:w-1/3 delay-[100ms] duration-[600ms] taos:translate-y-[2%] taos:opacity-0" data-taos-offset="300">
    <div class="sticky top-4 p-6 rounded-3xl shadow-lg space-y-6 bg-slate-50 bg-opacity-90">
      
      {# Back Navigation #}
      {% if page.parent %}
        <nav>
          <a href="{{ page.parent.url }}" class="inline-flex items-center text-blue-600 hover:text-blue-800 hover:underline transition-colors duration-200">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to {{ page.parent.title }}
          </a>
        </nav>
      {% endif %}
      
      {# Client Info #}
      {% if page.header.client %}
        <div class="client-info">
          <h2>{{ page.header.client }}</h2>
        </div>
      {% endif %}

      {# Project Details #}
      <div class="project-details space-y-4">
        {% if page.header.role %}
          <div class="detail-item">
            <label class="block text-sm font-medium text-gray-600 mb-1">Role</label>
            <p class="text-gray-900">{{ page.header.role }}</p>
          </div>
        {% endif %}

        {% if page.header.duration %}
          <div class="detail-item">
            <label class="block text-sm font-medium text-gray-600 mb-1">Duration</label>
            <p class="text-gray-900">{{ page.header.duration }}</p>
          </div>
        {% endif %}

        {% if page.header.year %}
          <div class="detail-item">
            <label class="block text-sm font-medium text-gray-600 mb-1">Year</label>
            <p class="text-gray-900">{{ page.header.year }}</p>
          </div>
        {% endif %}

        {% if page.header.project_type %}
          <div class="detail-item">
            <label class="block text-sm font-medium text-gray-600 mb-1">Deliverable</label>
            <p class="text-gray-900">{{ page.header.project_type|replace({'-': ' '})|title }}</p>
          </div>
        {% endif %}
      </div>

      {# Tags #}
      {% if page.header.tags %}
        <div class="project-tags">
          <label class="block text-sm font-medium text-gray-600 mb-2">Tags</label>
          <div class="flex flex-wrap gap-2">
            {% for tag in page.header.tags %}
              <span class="inline-block bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded-full">
                {{ tag|replace({'-': ' '})|title }}
              </span>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {# Project URL #}
      {% if page.header.project_url %}
        <div class="project-action">
          <a 
            class="btn btn-lg btn-primary font- bg-black text-white"
            href="{{ page.header.project_url }}" 
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
            Visit Site
          </a>
        </div>
      {% endif %}
    </div>
  </aside>
</div>

{# Challenge & Solution Section #}
{% if page.header.challenge or page.header.solution %}
  <section class="p-site pt-0">
    <div class="bg-slate-50 flex flex-col lg:flex-row p-8 gap-x-12 gap-y-8 rounded-3xl shadow-lg delay-[150ms] duration-[300ms] taos:translate-y-[10%] taos:opacity-0" data-taos-offset="300">
      
      {% if page.header.challenge %}
        <div class="w-full lg:w-1/2">
          <h2 class="mb-4">Challenges</h2>
          <div class="prose max-w-none text-gray-700">
            <ul class="list-disc list-outside ml-0 space-y-3">
              {% for line in page.header.challenge|split('\n') %}
                {% if line|trim %}
                  <li class="pl-0">{{ line|trim }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}

      {% if page.header.solution %}
        <div class="w-full lg:w-1/2">
          <h2 class="mb-4">Solutions</h2>
          <div class="prose max-w-none text-gray-700">
            <ul class="list-disc list-outside ml-0 space-y-3">
              {% for line in page.header.solution|split('\n') %}
                {% if line|trim %}
                  <li>{{ line|trim|raw }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}

{# Design Process Section #}
<section class="p-site pt-0">
  <div class="bg-black flex flex-col lg:flex-row p-8 gap-x-12 gap-y-8 rounded-3xl shadow-lg delay-[150ms] duration-[300ms] taos:translate-y-[10%] taos:opacity-0" data-taos-offset="300">
    <div class="w-full lg:w-1/2">
      <h2 class="mb-4 text-white">Design Process</h2>
    </div>
    <div class="w-full lg:w-1/2">
      <div class="prose max-w-none">
        <ul class="text-white list-disc list-outside ml-0 space-y-3">
        {% for line in page.header.design_process|split('\n') %}
          {% if line|trim %}
            <li class="text-white/90 text-inherit">{{ line|trim|raw }}</li>
          {% endif %}
        {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

{# Modal for Gallery #} 
{% if page.header.project_media %}
  {% include 'partials/modal.html.twig' %}
{% endif %}

{% endblock %}
